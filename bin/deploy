#!/usr/bin/env bash
set -euo pipefail

IMAGE="${IMAGE:-akitaonrails/frankmd:latest}"
SSH_HOST="${SSH_HOST:-akitaonrails@192.168.0.90}"
REMOTE_DIR="${REMOTE_DIR:-/var/opt/docker/frank/md}"
SSH_OPTS=(
  -F /dev/null
  -o StrictHostKeyChecking=no
  -o UserKnownHostsFile=/tmp/codex_known_hosts
)

echo "==> Building $IMAGE..."
docker build -t "$IMAGE" .

echo "==> Pushing $IMAGE..."
docker push "$IMAGE"

echo "==> Restarting FrankMD on $SSH_HOST..."
ssh "${SSH_OPTS[@]}" "$SSH_HOST" "cd $REMOTE_DIR && docker compose pull && docker compose down && docker compose up -d"

echo "==> Done!"
